@model IEnumerable<RestauranteApp.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="page-card">
    <div class="section-header">
        <div>
            <p class="eyebrow">Cadastro</p>
            <h1 class="section-title">Clientes</h1>
        </div>
        <a asp-action="Create" class="btn btn-primary">Novo cliente</a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Telefone</th>
                    <th>E-mail</th>
                    <th class="text-end">Acoes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model)
                {
                    <tr>
                        <td>@cliente.Nome</td>
                        <td>@cliente.Telefone</td>
                        <td>@cliente.Email</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@cliente.IdCliente" class="btn btn-sm btn-outline-primary">Detalhes</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
