@model RestauranteApp.Models.Reserva

@{
    ViewData["Title"] = "Editar Reserva";
}

<div class="form-shell">
    <div class="section-header">
        <div>
            <p class="eyebrow">Area do Administrador</p>
            <h1 class="section-title">Editar reserva</h1>
        </div>
        <a asp-action="Admin" class="btn btn-outline-primary">Voltar</a>
    </div>

    <div class="info-banner compact">
        <h3>Campo administrativo</h3>
        <p>Somente o administrador pode alterar status, mesa, cliente e demais dados da reserva.</p>
    </div>

    <form asp-action="Edit" method="post" class="row g-3">
        <input asp-for="IdReserva" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-6">
            <label asp-for="IdCliente" class="form-label"></label>
            <select asp-for="IdCliente" asp-items="ViewBag.Clientes" class="form-select"></select>
        </div>

        <div class="col-md-6">
            <label asp-for="IdMesa" class="form-label"></label>
            <select asp-for="IdMesa" asp-items="ViewBag.IdMesa" class="form-select"></select>
        </div>

        <div class="col-md-4">
            <label asp-for="DataReserva" class="form-label"></label>
            <input asp-for="DataReserva" type="date" class="form-control reserva-data" min="@ViewBag.DataMinima" />
        </div>

        <div class="col-md-4">
            <label asp-for="Horario" class="form-label"></label>
            <input asp-for="Horario"
                   type="time"
                   class="form-control reserva-horario"
                   min="@ViewBag.HorarioAbertura"
                   max="@ViewBag.HorarioEncerramento"
                   data-min-hoje="@ViewBag.HorarioMinimoHoje"
                   data-min-padrao="@ViewBag.HorarioAbertura"
                   data-max-horario="@ViewBag.HorarioEncerramento" />
        </div>

        <div class="col-md-4">
            <label asp-for="QuantidadePessoas" class="form-label"></label>
            <input asp-for="QuantidadePessoas" class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" asp-items="ViewBag.Status" class="form-select"></select>
        </div>

        <div class="col-12">
            <label asp-for="PedidoReserva" class="form-label"></label>
            <textarea asp-for="PedidoReserva" class="form-control" rows="4"></textarea>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Salvar alteracoes</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
