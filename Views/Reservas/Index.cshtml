@model IEnumerable<RestauranteApp.Models.Reserva>

@{
    ViewData["Title"] = "Reservas";
}

<div class="page-card">

    <div class="section-header mb-3">
        <div>
            <p class="eyebrow">Area do Cliente</p>
            <h1 class="section-title">Consultar reservas</h1>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-primary">Nova Reserva</a>
            <a asp-action="Admin" class="btn btn-outline-secondary">Painel Admin</a>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    <table class="table table-striped table-hover">

        <thead>
            <tr>
                <th>Cliente</th>
                <th>Mesa</th>
                <th>Data</th>
                <th>Horário</th>
                <th>Pessoas</th>
                <th>Pedido</th>
                <th>Status</th>
                <th>Acoes</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Cliente?.Nome</td>
                    <td>@item.Mesa?.Numero</td>
                    <td>@item.DataReserva.ToShortDateString()</td>
                    <td>@item.Horario</td>
                    <td>@item.QuantidadePessoas</td>
                    <td>@(string.IsNullOrWhiteSpace(item.PedidoReserva) ? "Nao informado" : item.PedidoReserva)</td>

                    <td>
                        @if (item.Status == "confirmada")
                        {
                            <span class="status-pill success">Confirmada</span>
                        }
                        else if (item.Status == "pendente")
                        {
                            <span class="status-pill warning">Pendente</span>
                        }
                        else if (item.Status == "cancelada")
                        {
                            <span class="status-pill danger">Cancelada</span>
                        }
                        else
                        {
                            <span class="status-pill">@item.Status</span>
                        }
                    </td>

                    <td>
                        <a asp-action="Details" asp-route-id="@item.IdReserva" class="btn btn-info btn-sm">
                            Detalhes
                        </a>
                    </td>

                </tr>
            }
        </tbody>

    </table>
</div>
