@model RestauranteApp.Models.Reserva

@{
    ViewData["Title"] = "Nova Reserva";
}

<div class="form-shell">
    <div class="section-header">
        <div>
            <p class="eyebrow">Area do Cliente</p>
            <h1 class="section-title">Nova reserva</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary">Voltar</a>
    </div>

    <div class="info-banner compact">
        <h3>Campo do cliente</h3>
        <p>
            Cliente logado: <strong>@ViewBag.ClienteLogado</strong><br />
            O cliente pode cadastrar a reserva apenas para a data atual ou datas futuras. O restaurante aceita reservas
            das @ViewBag.HorarioAbertura as @ViewBag.HorarioEncerramento e exige pelo menos 1 hora de antecedencia para o dia atual.
        </p>
    </div>

    <form asp-action="Create" method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-6">
            <label asp-for="IdMesa" class="form-label"></label>
            <select asp-for="IdMesa" asp-items="ViewBag.IdMesa" class="form-select">
                <option value="">Selecione uma mesa</option>
            </select>
            <span asp-validation-for="IdMesa" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="DataReserva" class="form-label"></label>
            <input asp-for="DataReserva" type="date" class="form-control reserva-data" min="@ViewBag.DataMinima" />
            <span asp-validation-for="DataReserva" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Horario" class="form-label"></label>
            <input asp-for="Horario"
                   type="time"
                   class="form-control reserva-horario"
                   min="@ViewBag.HorarioAbertura"
                   max="@ViewBag.HorarioEncerramento"
                   data-min-hoje="@ViewBag.HorarioMinimoHoje"
                   data-min-padrao="@ViewBag.HorarioAbertura"
                   data-max-horario="@ViewBag.HorarioEncerramento" />
            <span asp-validation-for="Horario" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="QuantidadePessoas" class="form-label"></label>
            <input asp-for="QuantidadePessoas" class="form-control" />
            <span asp-validation-for="QuantidadePessoas" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="PedidoReserva" class="form-label"></label>
            <textarea asp-for="PedidoReserva" class="form-control" rows="4" placeholder="Ex.: Prato principal: risoto de filet | Bebida: suco de uva | Sobremesa: petit gateau"></textarea>
            <span asp-validation-for="PedidoReserva" class="text-danger"></span>
            <small class="form-helper">Este campo e voltado ao cliente para registrar o pedido antecipado.</small>
        </div>

        <input asp-for="Status" type="hidden" value="pendente" />

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Salvar reserva</button>
            <a asp-controller="Mesas" asp-action="Index" class="btn btn-outline-secondary">Ver mesas</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
