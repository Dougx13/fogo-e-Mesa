@{
    ViewData["Title"] = "Para o amor da minha vida";
}

<section class="love-note">
    <div class="love-note__glow love-note__glow--one"></div>
    <div class="love-note__glow love-note__glow--two"></div>

    <div class="love-note__card">
        <p class="love-note__eyebrow">Uma mensagem para Roberta</p>
        <h1>Roberta 💖</h1>

        <p class="love-note__text">
            Sei que nao esta facil, mas quero que voce se lembre de uma coisa: eu estou aqui por voce e sempre vou estar.
            Voce e muito mais do que o meu mundo, e a pessoa que me da forcas para continuar todos os dias. Quero fazer o
            mesmo por ti, com carinho, paciencia e amor.
        </p>

        <p class="love-note__text">
            Voce fez muito hoje, lutou bastante, e eu tenho muito orgulho de voce. Mesmo quando tudo parece pesado, o
            amor verdadeiro abraca, fortalece e faz a gente respirar melhor.
        </p>

        <blockquote class="love-note__quote">
            Call It What You Want
            <span>Mesmo depois de tudo, o amor verdadeiro te fortalece.</span>
        </blockquote>

        <div class="love-note__music">
            <button id="play-music" type="button" class="btn love-note__button love-note__button--music">
                Tocar musica fofa 🎵
            </button>
            <p class="love-note__music-hint">A musica abre aqui na pagina e continua tocando enquanto a mensagem aparece.</p>
            <div class="love-note__player" id="music-player" hidden>
                <iframe id="music-frame"
                        width="100%"
                        height="152"
                        src=""
                        title="Musica fofa"
                        allow="autoplay; encrypted-media"
                        referrerpolicy="strict-origin-when-cross-origin">
                </iframe>
            </div>
        </div>

        <div class="love-note__question">
            <h2>Aceita beijinhos? 🥺</h2>
            <div class="love-note__actions" id="love-actions">
                <button id="sim" type="button" class="btn love-note__button love-note__button--yes">Sim ❤️</button>
                <button id="nao" type="button" class="btn love-note__button love-note__button--no">Nao 😢</button>
            </div>
            <div class="love-note__message" id="mensagem" aria-live="polite">
                💖 Eu sabia. Voce me faz muito feliz, Roberta. 💖
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const noButton = document.getElementById("nao");
            const yesButton = document.getElementById("sim");
            const message = document.getElementById("mensagem");
            const actions = document.getElementById("love-actions");
            const playMusicButton = document.getElementById("play-music");
            const musicPlayer = document.getElementById("music-player");
            const musicFrame = document.getElementById("music-frame");

            const musicEmbedUrl = "https://www.youtube.com/embed/-BjZmE2gtdo?autoplay=1&loop=1&playlist=-BjZmE2gtdo";
            const redirectVideoUrl = "https://www.youtube.com/watch?v=-BjZmE2gtdo";

            if (!noButton || !yesButton || !message || !actions || !playMusicButton || !musicPlayer || !musicFrame) {
                return;
            }

            const moveNoButton = () => {
                if (window.innerWidth < 768) {
                    return;
                }

                const bounds = actions.getBoundingClientRect();
                const maxX = Math.max(0, bounds.width - noButton.offsetWidth);
                const maxY = Math.max(0, 140 - noButton.offsetHeight);
                const nextX = Math.random() * maxX;
                const nextY = Math.random() * maxY;

                noButton.style.left = `${nextX}px`;
                noButton.style.top = `${nextY}px`;
            };

            playMusicButton.addEventListener("click", () => {
                if (!musicFrame.src) {
                    musicFrame.src = musicEmbedUrl;
                }

                musicPlayer.hidden = false;
                playMusicButton.textContent = "Musica tocando 💗";
                playMusicButton.disabled = true;
            });

            noButton.addEventListener("mouseenter", moveNoButton);
            noButton.addEventListener("click", moveNoButton);

            yesButton.addEventListener("click", () => {
                message.classList.add("is-visible");

                setTimeout(() => {
                    window.location.href = redirectVideoUrl;
                }, 1200);
            });
        })();
    </script>
}
