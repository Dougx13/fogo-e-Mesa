@{
    ViewData["Title"] = "Sobre o Sistema";
}

<div class="container mt-4">

    <h2 class="mb-4">🔥 Fogo & Mesa - Sistema de Reservas</h2>

    <div class="card shadow">
        <div class="card-body">

            <h4>Sobre o Projeto</h4>
            <p>
                O sistema Fogo & Mesa foi desenvolvido para facilitar o gerenciamento
                de reservas em restaurantes, proporcionando uma melhor organização
                e uma experiência mais eficiente para clientes e funcionários.
            </p>

            <hr />

            <h4>Funcionalidades</h4>

            <ul>
                <li>Cadastro de Clientes</li>
                <li>Cadastro de Mesas</li>
                <li>Reserva de Mesas</li>
                <li>Controle de Status de Reserva</li>
                <li>Listagem de Reservas</li>
            </ul>

            <hr />

            <h4>Tecnologias Utilizadas</h4>

            <ul>
                <li>ASP.NET Core MVC</li>
                <li>Entity Framework</li>
                <li>SQL Server</li>
                <li>Bootstrap</li>
            </ul>

            <hr />

            <h4>Objetivo</h4>

            <p>
                Melhorar a organização do restaurante, reduzir tempo de espera
                e oferecer uma experiência mais agradável ao cliente.
            </p>

        </div>
    </div>

</div>