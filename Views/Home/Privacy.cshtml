@{
    ViewData["Title"] = "Sobre o Sistema";
}

<div class="container mt-4">

    <h2 class="mb-4 text-white">🔥 Fogo & Mesa - Sistema de Gestão de Restaurante</h2>

    <div class="card shadow">
        <div class="card-body">

            <h4>Sobre o Projeto</h4>
            <p>
                O sistema Fogo & Mesa foi desenvolvido para facilitar o gerenciamento
                de reservas em restaurantes, proporcionando uma melhor organização
                e uma experiência mais eficiente para clientes e funcionários.
            </p>

            <p>
                A aplicação permite que o restaurante tenha controle completo das reservas,
                clientes, mesas e produtos, garantindo um atendimento mais rápido,
                organizado e profissional.
            </p>

            <hr />

            <h4>Funcionalidades</h4>

            <ul>
                <li>Cadastro de Clientes</li>
                <li>Cadastro de Mesas</li>
                <li>Reserva de Mesas</li>
                <li>Controle de Status de Reserva</li>
                <li>Listagem de Reservas</li>
                <li>Cadastro de Produtos</li>
                <li>Controle de Pedidos</li>
                <li>Controle de Pagamentos</li>
                <li>Avaliação do Atendimento</li>
            </ul>

            <hr />

            <h4>Benefícios do Sistema</h4>

            <ul>
                <li>Melhor organização do restaurante</li>
                <li>Redução do tempo de espera</li>
                <li>Controle das reservas</li>
                <li>Melhor atendimento ao cliente</li>
                <li>Facilidade no gerenciamento</li>
            </ul>

            <hr />

            <h4>Tecnologias Utilizadas</h4>

            <ul>
                <li>ASP.NET Core MVC</li>
                <li>Entity Framework</li>
                <li>SQL Server</li>
                <li>Bootstrap</li>
                <li>HTML, CSS e JavaScript</li>
            </ul>

            <hr />

            <h4>Objetivo</h4>

            <p>
                Melhorar a organização do restaurante, reduzir tempo de espera
                e oferecer uma experiência mais agradável ao cliente, além de
                facilitar o controle administrativo e operacional do estabelecimento.
            </p>

        </div>
    </div>

</div>